// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── 14-Industry Taxonomy ──────────────────────────────────────────
// logistics, mining, trading, pharma, retail, energy, automotive,
// accounting, government, construction, cross_border, air_cargo,
// warehousing, trade_finance

model Workspace {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  industry      String   @default("logistics")
  plan          String   @default("pilot") // pilot, starter, professional, enterprise
  whatsappConnected Boolean @default(false)
  emailConnected   Boolean @default(false)
  onboardingComplete Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users        User[]
  shipments    Shipment[]
  metrics      DashboardMetric[]
  channels     IngestionChannel[]
  industryRules IndustryRule[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        String   @default("operations") // ceo, operations, finance
  avatar      String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}

model IndustryRule {
  id          String   @id @default(cuid())
  industry    String   // matches the 14-industry taxonomy
  ruleName    String   // e.g. "weight_variance", "grade_under_spec", "vin_error"
  logicDesc   String   // Human-readable description for the Auditor Agent
  impactMultiplier Float @default(1.0) // Financial impact multiplier for Risk Analyst
  severity    String   @default("medium") // low, medium, high, critical
  category    String   @default("mismatch") // mismatch, compliance, fraud, delay
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  workspaceId String?
}

model Shipment {
  id             String   @id @default(cuid())
  reference      String   @unique
  title          String
  industry       String   @default("logistics")
  status         String   @default("pending") // pending, processing, cleared, flagged, held
  origin         String?
  destination    String?
  supplier       String?
  buyer          String?
  totalAmount    Float?
  currency       String   @default("ZAR")
  grossWeightKg  Float?
  commodity      String?
  hsCode         String?
  riskLevel      String   @default("low") // low, medium, high, critical
  riskNotes      String?
  estimatedValue Float?
  workspaceId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace?   @relation(fields: [workspaceId], references: [id])
  documents    Document[]
  agentLogs    AgentLog[]
  alerts       Alert[]
  auditTrails  AuditTrail[]
  timeline     TimelineEvent[]
}

model Document {
  id            String   @id @default(cuid())
  shipmentId    String
  fileName      String
  fileType      String   // invoice, bol, packing_list, air_waybill, permit, assay_cert, batch_cert, vin_report, boq, swift_confirm, grv, etc.
  source        String   @default("upload") // upload, email, whatsapp
  content       String?
  extractedData String?
  status        String   @default("pending") // pending, processed, exception, critical
  ocrConfidence Float?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id          String   @id @default(cuid())
  shipmentId  String
  agentName   String   // triage_clerk, data_extractor, auditor, risk_analyst, dispatcher
  agentRole   String   // Router, OCR Specialist, Validator, Decision Maker, Communicator
  status      String   @default("running") // running, completed, failed
  input       String?
  output      String?
  duration    Int?
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Alert {
  id          String   @id @default(cuid())
  shipmentId  String
  type        String   // mismatch, risk, delay, compliance, fraud, info
  severity    String   @default("medium") // low, medium, high, critical
  title       String
  message     String
  channel     String   @default("dashboard") // dashboard, whatsapp, email
  isRead      Boolean  @default(false)
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model AuditTrail {
  id          String   @id @default(cuid())
  shipmentId  String
  action      String
  agentName   String?
  details     String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  event       String
  description String
  agentName   String?
  icon        String?
  timestamp   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model DashboardMetric {
  id          String   @id @default(cuid())
  key         String
  value       Float
  label       String
  unit        String?
  workspaceId String?
  updatedAt   DateTime @updatedAt

  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}

model IngestionChannel {
  id          String   @id @default(cuid())
  type        String   // email, whatsapp, api
  config      String   // JSON config
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?
  workspaceId String?
  createdAt   DateTime @default(now())

  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}
